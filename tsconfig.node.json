{
	"compilerOptions": {
		"composite": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
		"target": "ES2022",
		"lib": ["ES2023"],
		"module": "ES2022",
		"moduleResolution": "bundler",
		"types": ["node"],
		"esModuleInterop": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"noEmit": true,
		"skipLibCheck": true,
		"strict": true
	},
	"include": ["vite.config.ts", "react-router.config.ts"]
}
